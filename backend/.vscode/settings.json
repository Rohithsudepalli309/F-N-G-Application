{
    // Re-enable Jest only for this folder (overrides workspace-root jest.enable: false).
    "jest.enable": true,
    "jest.jestCommandLine": "npx jest",
    "jest.rootPath": ".",
    "jest.autoRun": {
        "watch": false,
        "onStartup": ["all-tests"]
    },

    // SQL dialect — migrations target PostgreSQL, not T-SQL.
    // This suppresses false-positive errors for PostgreSQL-only syntax such as
    // "ADD COLUMN IF NOT EXISTS" which is perfectly valid in Postgres but unknown
    // to the SQL Server lint engine that VS Code uses by default.
    "sql.lintingEnabled": false
}
