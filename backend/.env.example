# Required
DATABASE_URL=postgresql://fng_user:fng_pass@localhost:5432/fng_db
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
PORT=3002
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Optional: set to 'true' when using hosted PostgreSQL (e.g. Supabase, RDS)
DATABASE_SSL=false

# Razorpay (optional — only needed for online payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── SMS / OTP provider ────────────────────────────────────────────────────────
# Set SMS_PROVIDER to one of: console | msg91 | twilio
# Leave as 'console' for local development (OTP printed to stdout).
SMS_PROVIDER=console

# MSG91 (recommended for India)
# Sign up at https://msg91.com — create an OTP template and copy the values below.
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=FNGAPP

# Twilio (global alternative)
# Sign up at https://twilio.com — use a phone number with SMS capability.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Firebase Cloud Messaging — push notifications (optional)
# Paste the entire service account JSON as a single-line string.
FIREBASE_SERVICE_ACCOUNT_JSON=
