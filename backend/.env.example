# Required
DATABASE_URL=postgresql://fng_user:fng_pass@localhost:5432/fng_db
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
PORT=3002
NODE_ENV=development

# Redis is optional in local dev and enabled by default in production.
# Set to true only when a Redis instance is running and reachable.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Optional: set to 'true' when using hosted PostgreSQL (e.g. Supabase, RDS)
DATABASE_SSL=false
# When DATABASE_SSL=true, paste your provider's root CA certificate (PEM) here.
# Supabase:  Dashboard → Settings → Database → "SSL Certificate" → copy contents.
# AWS RDS:   https://truststore.pki.rds.amazonaws.com/<region>/<region>-bundle.pem
# Format:    single-line PEM with literal \n between lines, or use a multiline block.
# Leave blank to use Node's built-in trusted CAs (works for most providers).
DATABASE_SSL_CA=

# Razorpay (optional — only needed for online payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Application Insights (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── SMS / OTP provider ────────────────────────────────────────────────────────
# Set SMS_PROVIDER to one of: console | msg91 | twilio
# Leave as 'console' for local development (OTP printed to stdout).
SMS_PROVIDER=console

# MSG91 (recommended for India)
# Sign up at https://msg91.com — create an OTP template and copy the values below.
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=FNGAPP

# Twilio (global alternative)
# Sign up at https://twilio.com — use a phone number with SMS capability.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Firebase Cloud Messaging — push notifications (optional)
# Paste the entire service account JSON as a single-line string.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Storage configuration for product images
# Set STORAGE_DRIVER=local for dev (saves to backend/uploads)
# Set STORAGE_DRIVER=s3 for S3 uploads (S3 integration not implemented yet)
STORAGE_DRIVER=local
# When STORAGE_DRIVER=local, files are stored in LOCAL_UPLOAD_DIR. Default: <repo-root>/uploads
LOCAL_UPLOAD_DIR=
# Optionally set STORAGE_BASE_URL to the CDN or public prefix for uploaded files.
# When blank, backend serves files at /uploads/<filename>
STORAGE_BASE_URL=

# S3 configuration (when STORAGE_DRIVER=s3)
S3_BUCKET=
AWS_REGION=
# AWS credentials are picked up from environment variables or IAM roles.
# You can set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY here for local testing.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
