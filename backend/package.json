{
  "name": "fng-backend",
  "version": "1.0.0",
  "private": true,
  "description": "F&G Application Backend — Express + PostgreSQL + Socket.IO",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "migrate": "node migrate.js",
    "migrate:status": "node migrate.js --status",
    "seed": "ts-node-dev --transpile-only src/seed.ts"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "applicationinsights": "^2.9.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^12.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "multer": "^1.4.5-lts.1",
    "@aws-sdk/client-s3": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "opossum": "^8.1.4",
    "pg": "^8.11.5",
    "rate-limit-redis": "^4.3.1",
    "razorpay": "^2.9.2",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
