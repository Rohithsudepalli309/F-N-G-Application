# Customer App — Environment Config
# Copy this file to .env and fill in your values.
# Metro will pick it up automatically via the babel-plugin-dotenv-import plugin.

# ── Server address ─────────────────────────────────────────────────────────────
# Physical device (Wi-Fi): your dev machine's LAN IP
# Physical device (USB Android): 127.0.0.1  (after: adb reverse tcp:3002 tcp:3002)
# Android emulator: 10.0.2.2
# iOS simulator:    127.0.0.1
API_HOST=192.168.221.78
API_PORT=3002

# Production API base (used when NODE_ENV=production)
API_PROD_ORIGIN=https://api.fng.in
